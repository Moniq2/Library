<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.biblioteca.controller.EmprestimoCardController">
    <children>
        <GridPane fx:id="emprestimoGrid" alignment="CENTER" layoutX="32.0" layoutY="90.0" minWidth="900.0" styleClass="card-emprestimo" stylesheets="@../css/style.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="50.0" prefWidth="180.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="50.0" prefWidth="50.0" />
            <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="50.0" prefWidth="50.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" valignment="CENTER" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label fx:id="tituloLabel" text="Título" textAlignment="CENTER">
               <padding>
                  <Insets left="10.0" />
               </padding></Label>
                <Label fx:id="dataEntregaLabel" text="Data de entrega" GridPane.columnIndex="2" />
                <Label GridPane.columnIndex="3" />
            <Button fx:id="renovarButton" mnemonicParsing="false" onAction="#renovar" styleClass="botao-acao" stylesheets="@../css/style.css" text="Renovar" GridPane.columnIndex="3" />
            <Button fx:id="devolverButton" mnemonicParsing="false" onAction="#devolver" styleClass="botao-acao" text="Devolver" GridPane.columnIndex="4" />
            <Label fx:id="autorLabel" text="Autor" GridPane.columnIndex="1" />
            </children>
        </GridPane>
    </children>
</AnchorPane>
